{
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/staff/assets/:path*", "destination": "/staff-portal/dist/assets/:path*" },
    { "source": "/staff/:path*", "destination": "/staff-portal/dist/index.html" },
    { "source": "/assets/:path*", "destination": "/admin-dashboard/dist/assets/:path*" },
    { "source": "/favicon.svg", "destination": "/admin-dashboard/dist/favicon.svg" },
    { "source": "/manifest.json", "destination": "/admin-dashboard/dist/manifest.json" },
    { "source": "/sw.js", "destination": "/admin-dashboard/dist/sw.js" },
    { "source": "/icons/:path*", "destination": "/admin-dashboard/dist/icons/:path*" },
    { "source": "/((?!assets|staff|favicon|manifest|sw|icons).*)", "destination": "/admin-dashboard/dist/index.html" }
  ]
}
