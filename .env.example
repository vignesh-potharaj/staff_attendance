# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT Secret
SECRET_KEY=your-secret-key-here

# Google Drive Integration (OAuth2)
# 
# LOCAL DEVELOPMENT MODE:
# Download credentials.json from Google Cloud Console and save in project root
GOOGLE_CREDENTIALS_JSON=credentials.json
GOOGLE_TOKEN_PICKLE=token.pickle
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here

# PRODUCTION MODE (Render, Vercel, etc):
# Encode credentials.json and token.pickle as base64 and use environment variables
# See GOOGLE_DRIVE_OAUTH2_SETUP.md for instructions
# GOOGLE_CREDENTIALS_JSON_B64=<base64-encoded-credentials>
# GOOGLE_TOKEN_PICKLE_B64=<base64-encoded-token>
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here
